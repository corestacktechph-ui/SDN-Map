{
  "name": "SDN-MAP Mininet Environment",
  "image": "ubuntu:22.04",
  "runArgs": ["--privileged", "--cap-add=ALL", "--net=host"],
  "containerEnv": {
    "DEBIAN_FRONTEND": "noninteractive"
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "forwardPorts": [3000, 6633, 8080],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance"
      ]
    }
  }
}
